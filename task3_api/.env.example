# Flask Configuration
FLASK_ENV=development
DEBUG=True

# SQL Database Configuration
# Format: mysql+pymysql://username:password@host:port/database
DATABASE_URL=mysql+pymysql://root:@localhost/traffic_db

# MongoDB Configuration
# Local: mongodb://localhost:27017/traffic_db
# Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/traffic_db
MONGO_URI=mongodb://localhost:27017/traffic_db

# API Settings
API_PORT=5000
API_HOST=0.0.0.0

# Optional: For Future Features
# SECRET_KEY=your-secret-key-here
# JWT_SECRET=your-jwt-secret-here
